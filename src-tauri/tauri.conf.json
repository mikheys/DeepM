{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepM",
  "version": "0.3.0",
  "identifier": "com.deepm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeepM",
        "width": 900,
        "height": 600,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "engine/*",
      "tesseract/*",
      "tesseract/tessdata-standard/*"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": ["English", "Russian"]
      }
    }
  }
}
